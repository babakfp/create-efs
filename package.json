{
    "name": "create-efs",
    "description": "A CLI tool to create SvelteKit apps.",
    "version": "1.4.7",
    "license": "MIT",
    "scripts": {
        "dev": "rimraf dist && tsc -w",
        "build": "rimraf dist && tsc",
        "prepublishOnly": "rimraf -g templates/SvelteKit/{node_modules,.svelte-kit,static/error.css,vite.config.*.timestamp-*} && tsc",
        "format": "prettier -w ."
    },
    "dependencies": {
        "@clack/prompts": "1.6.0",
        "node-stream-zip": "1.15.0",
        "nodejs-file-downloader": "4.13.0"
    },
    "devDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "4.7.1",
        "@types/node": "24.13.2",
        "prettier": "3.8.4",
        "rimraf": "6.1.3",
        "typescript": "6.0.3"
    },
    "repository": "github:babakfp/create-efs",
    "main": "./dist/index.js",
    "bin": "./dist/index.js",
    "files": [
        "./dist/",
        "./templates/"
    ],
    "exports": {
        ".": "./dist/index.js"
    },
    "keywords": [
        "cli",
        "svelte",
        "create",
        "template",
        "scaffold"
    ],
    "packageManager": "pnpm@11.8.0",
    "type": "module"
}
